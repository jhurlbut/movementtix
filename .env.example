# Telegram bot credentials (talk to @BotFather to create one;
# message the bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your numeric chat_id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Free API key from https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=

# Reddit (for r/MovementDEMF resale + after-party post alerts).
# Create a "script" app at https://www.reddit.com/prefs/apps
# (any redirect URI works; client_secret will appear under the app name).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Your Reddit username (without u/). Used in the API User-Agent header
# so your usage is properly attributed per Reddit's API policy.
REDDIT_USERNAME=
